# Optional: explicitly select a database backend.
# Supported values: postgres | sqlite
# If empty, the app uses Postgres when a connection string is present,
# otherwise it falls back to SQLite.
DATABASE_PROVIDER=

# Optional: direct Postgres connection.
# DATABASE_PROVIDER=postgres requires one of these connection strings.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=

# Optional: local SQLite file path.
SQLITE_DATABASE_PATH=.sisyphus/local-data/app.db

# Admin session signing secret. Always set this explicitly for deployment.
ADMIN_SESSION_SECRET=your-admin-session-secret

# Turnstile is enabled only when both keys are present.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Local development usually uses development; containers / production use production.
NODE_ENV=development

# Model check polling interval, in seconds.
CHECK_POLL_INTERVAL_SECONDS=300

# Calendar day boundary used for daily success rate and status bars.
NEXT_PUBLIC_STATUS_DAY_TIME_ZONE=Asia/Shanghai

# History retention days, range 7-365.
HISTORY_RETENTION_DAYS=30

# Official status polling interval, in seconds.
OFFICIAL_STATUS_CHECK_INTERVAL_SECONDS=300

# Maximum concurrent provider checks.
CHECK_CONCURRENCY=5

# Telegram push Bot Token, Chat ID, and auto-push settings are configured in the admin UI.
